{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "RPW Launcher default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "http:default",
    "http:allow-fetch",
    "http:allow-fetch-send",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "shell:default",
    "shell:allow-open"
  ]
}
